generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String // Store hashed password
  role      String   @default("CLIENT") // ADMIN or CLIENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     TenantSite[]
  subscriptions Subscription[]
}

model TenantSite {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  slug        String   @unique // URL slug e.g. /sites/my-store
  siteName    String
  headline    String   @default("Welcome to our store")
  themeColor  String   @default("#2563eb")
  font        String   @default("Inter, sans-serif")
  status      String   @default("ACTIVE") // ACTIVE, SUSPENDED
  expiresAt   DateTime? // Subscription expiration date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  reservations Reservation[]
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  plan      String   // MONTHLY or ANNUAL
  status    String   @default("PENDING") // ACTIVE, PENDING, CANCELLED
  paypalId  String?  // To store PayPal subscription/order ID later
  startDate DateTime @default(now())
  endDate   DateTime?
}

model Product {
  id          String     @id @default(cuid())
  siteId      String
  site        TenantSite @relation(fields: [siteId], references: [id])
  name        String
  description String?
  price       Float
  imageUrl    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Reservation {
  id          String     @id @default(cuid())
  siteId      String
  site        TenantSite @relation(fields: [siteId], references: [id])
  customerName String
  customerEmail String
  date        DateTime
  status      String     @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
